{"ast":null,"code":"import{useState,useCallback,useEffect}from'react';const SECRET_PIN='246800';export function usePinInput(){let{onSuccess}=arguments.length>0&&arguments[0]!==undefined?arguments[0]:{};const[digits,setDigits]=useState([]);const[status,setStatus]=useState('idle');const[shake,setShake]=useState(false);const triggerShake=useCallback(()=>{setShake(true);setTimeout(()=>setShake(false),600);},[]);const handleKey=useCallback(key=>{if(status==='success'||status==='error')return;if(digits.length>=6)return;const next=[...digits,key];setDigits(next);if(next.length===6){if(next.join('')===SECRET_PIN){setStatus('success');onSuccess===null||onSuccess===void 0?void 0:onSuccess();}else{setStatus('error');triggerShake();}}},[digits,status,onSuccess,triggerShake]);const handleDelete=useCallback(()=>{if(status==='success'||status==='error')return;setDigits(prev=>prev.slice(0,-1));},[status]);const reset=useCallback(()=>{setDigits([]);setStatus('idle');setShake(false);},[]);useEffect(()=>{const onKeyDown=e=>{if(e.key>='0'&&e.key<='9')handleKey(e.key);if(e.key==='Backspace')handleDelete();};window.addEventListener('keydown',onKeyDown);return()=>window.removeEventListener('keydown',onKeyDown);},[handleKey,handleDelete]);return{digits,status,shake,handleKey,handleDelete,reset};}","map":{"version":3,"names":["useState","useCallback","useEffect","SECRET_PIN","usePinInput","onSuccess","arguments","length","undefined","digits","setDigits","status","setStatus","shake","setShake","triggerShake","setTimeout","handleKey","key","next","join","handleDelete","prev","slice","reset","onKeyDown","e","window","addEventListener","removeEventListener"],"sources":["/home/arzeyn/Downloads/arenaplus-pin/src/hooks/usePinInput.js"],"sourcesContent":["import { useState, useCallback, useEffect } from 'react';\n\nconst SECRET_PIN = '246800';\n\nexport function usePinInput({ onSuccess } = {}) {\n  const [digits, setDigits] = useState([]);\n  const [status, setStatus] = useState('idle');\n  const [shake, setShake]   = useState(false);\n\n  const triggerShake = useCallback(() => {\n    setShake(true);\n    setTimeout(() => setShake(false), 600);\n  }, []);\n\n  const handleKey = useCallback((key) => {\n    if (status === 'success' || status === 'error') return;\n    if (digits.length >= 6) return;\n\n    const next = [...digits, key];\n    setDigits(next);\n\n    if (next.length === 6) {\n      if (next.join('') === SECRET_PIN) {\n        setStatus('success');\n        onSuccess?.();\n      } else {\n        setStatus('error');\n        triggerShake();\n      }\n    }\n  }, [digits, status, onSuccess, triggerShake]);\n\n  const handleDelete = useCallback(() => {\n    if (status === 'success' || status === 'error') return;\n    setDigits(prev => prev.slice(0, -1));\n  }, [status]);\n\n  const reset = useCallback(() => {\n    setDigits([]);\n    setStatus('idle');\n    setShake(false);\n  }, []);\n\n  useEffect(() => {\n    const onKeyDown = (e) => {\n      if (e.key >= '0' && e.key <= '9') handleKey(e.key);\n      if (e.key === 'Backspace') handleDelete();\n    };\n    window.addEventListener('keydown', onKeyDown);\n    return () => window.removeEventListener('keydown', onKeyDown);\n  }, [handleKey, handleDelete]);\n\n  return {\n    digits,\n    status,\n    shake,\n    handleKey,\n    handleDelete,\n    reset,\n  };\n}"],"mappings":"AAAA,OAASA,QAAQ,CAAEC,WAAW,CAAEC,SAAS,KAAQ,OAAO,CAExD,KAAM,CAAAC,UAAU,CAAG,QAAQ,CAE3B,MAAO,SAAS,CAAAC,WAAWA,CAAA,CAAqB,IAApB,CAAEC,SAAU,CAAC,CAAAC,SAAA,CAAAC,MAAA,IAAAD,SAAA,MAAAE,SAAA,CAAAF,SAAA,IAAG,CAAC,CAAC,CAC5C,KAAM,CAACG,MAAM,CAAEC,SAAS,CAAC,CAAGV,QAAQ,CAAC,EAAE,CAAC,CACxC,KAAM,CAACW,MAAM,CAAEC,SAAS,CAAC,CAAGZ,QAAQ,CAAC,MAAM,CAAC,CAC5C,KAAM,CAACa,KAAK,CAAEC,QAAQ,CAAC,CAAKd,QAAQ,CAAC,KAAK,CAAC,CAE3C,KAAM,CAAAe,YAAY,CAAGd,WAAW,CAAC,IAAM,CACrCa,QAAQ,CAAC,IAAI,CAAC,CACdE,UAAU,CAAC,IAAMF,QAAQ,CAAC,KAAK,CAAC,CAAE,GAAG,CAAC,CACxC,CAAC,CAAE,EAAE,CAAC,CAEN,KAAM,CAAAG,SAAS,CAAGhB,WAAW,CAAEiB,GAAG,EAAK,CACrC,GAAIP,MAAM,GAAK,SAAS,EAAIA